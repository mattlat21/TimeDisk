# Copy to .env and fill in your SFTP settings ( .env is gitignored ).

# Remote server — use the SSH/SFTP hostname from NFSN Site Information, NOT your web domain.
SFTP_HOST=ssh.nyc1.nearlyfreespeech.net
SFTP_PORT=22
# Format: memberlogin_sitename (from NFSN "SSH/SFTP Information" box)
SFTP_USER=yourmember_yoursite

# Automated uploads (scripts) on Nearly Free Speech REQUIRE an SSH key in your member
# keychain (Profile tab). Password-only works for interactive clients, not sshpass/scripts.
SFTP_KEY_PATH=/Users/you/.ssh/nfsn_timedisk

# Password auth only works for manual/interactive SFTP — not for upload_firmware.sh.
# SFTP_PASSWORD=your_member_password

# NFSN SSH lands in site home; web files live under /home/public.
# URL http://latimer.net/files/tdisk/latest.bin -> SFTP path below:
SFTP_REMOTE_DIR=/home/public/files/tdisk
SFTP_REMOTE_FILENAME=latest.bin
